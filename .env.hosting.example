APP_NAME=UEMKASOLVE
APP_TAGLINE="Solusi UMKM"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta
APP_URL=https://uemkasolve.my.id

APP_LOCALE=id
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
CACHE_STORE=database
CACHE_PREFIX=

# Gmail SMTP untuk verifikasi email, reset password, dan invitation staff.
# MAIL_PASSWORD wajib memakai Gmail App Password 16 karakter dari Google Account,
# bukan password login Gmail biasa.
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=uemkasolve@gmail.com
MAIL_PASSWORD=Uemkasolve123
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=uemkasolve@gmail.com
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://uemkasolve.my.id/auth/google/callback
